# 复制为 .env 后填写；勿提交含密钥的 .env
# 主 RPC（可与备节点不同，实现轮询 + 429 时自动换节点）
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# 备 RPC（可选；与主地址不同才会启用）
VITE_SOLANA_RPC_URL_SECONDARY=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# 需要 web3.js 对 HTTP 429 做指数退避重试时再设 true（默认关闭，避免连打 RPC + 刷 console）
# VITE_SOLANA_RPC_RETRY_429=true
